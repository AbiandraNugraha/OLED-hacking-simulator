void loop() {

 // --- 2. RANDOM SLIDING SCOPE (3 SECONDS) ---
  int currentX = 66, currentY = 32;               // Start at center
  int targetX = random(20, 110), targetY = random(10, 50); // First random target
  uint32_t searchStartTime = millis();

  while (millis() - searchStartTime < 3000) {
    u8g2.clearBuffer();
    u8g2.drawXBMP(2, 0, 128, 64, my_earth_bitmap); // Map Background centered

    // Slide logic: Move current scope position toward the random target
    if (currentX < targetX) currentX += 3;
    if (currentX > targetX) currentX -= 3;
    if (currentY < targetY) currentY += 3;
    if (currentY > targetY) currentY -= 3;

    // When target is reached, pick a new random spot
    if (abs(currentX - targetX) < 5 && abs(currentY - targetY) < 5) {
      targetX = random(20, 110);
      targetY = random(10, 50);
      delay(50); // Tiny pause at each target point
    }

    // Draw Sliding Scope (Scope shape)
    u8g2.drawCircle(currentX, currentY, 12);
    u8g2.drawLine(currentX - 18, currentY, currentX + 18, currentY);
    u8g2.drawLine(currentX, currentY - 18, currentX, currentY + 18);
    
    // Add "SCANNING" status text
    u8g2.setFont(u8g2_font_5x8_tr);
    u8g2.drawStr(2, 10, "SCANNING...");
    
    u8g2.sendBuffer();
    delay(20); // Adjust speed of sliding here
  }
  // --- 3. FOUND & BLINKING ---
  u8g2.setFont(u8g2_font_6x12_tr);
  for (int i = 0; i < 6; i++) {
    u8g2.clearBuffer();
    u8g2.drawXBMP(2, 0, 128, 64, my_earth_bitmap);
    
    if (i % 2 == 0) {
       u8g2.drawDisc(71, 26, 3); // Titik lokasi
       u8g2.drawStr(28, 60, "Device found");
    }
    u8g2.sendBuffer();
    delay(500);
  }

  // --- 4. STATUS MENYAMBUNG ---
  u8g2.clearBuffer();
  u8g2.drawStr(10, 28, "Connecting");
